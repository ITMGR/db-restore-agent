MARIADB_DATABASE=crz
MARIADB_USER=crz
MARIADB_PASSWORD=crz-opt-dev
MARIADB_ROOT_PASSWORD=crz-opt-root-dev
MARIADB_PORT=53306

# Restore tuning defaults. Override per run when needed.
RESTORE_MAX_ALLOWED_PACKET=1G
MARIADB_KEY_BUFFER_SIZE=4G
MARIADB_BULK_INSERT_BUFFER_SIZE=1G
MARIADB_MYISAM_SORT_BUFFER_SIZE=4G
MARIADB_ARIA_PAGECACHE_BUFFER_SIZE=1G
MARIADB_INNODB_BUFFER_POOL_SIZE=4G
MARIADB_INNODB_LOG_FILE_SIZE=1G
PRUNE_DATA_TABLE_REGEX=^(log_[0-9]+|counter_[0-9]+|robot_01|robot_02|elastic1)$

# Restore worker defaults. RESTORE_WORKER_PROJECT_DIR must match the host-side
# project path seen by Docker daemon when the worker uses /var/run/docker.sock.
RESTORE_WORKER_PROJECT_DIR=/data/deploy/openclaw/config/workspace/projects/crz-opt
DUMP_WATCH_DIR=/data/deploy/openclaw/config/workspace/projects/crz-opt/data/dumps
RESTORE_STATE_DIR=/data/deploy/openclaw/config/workspace/projects/crz-opt/data/restore-state
RESTORE_POLL_INTERVAL=60
RESTORE_STABLE_SECONDS=120
RESTORE_ON_START=true
RESTORE_WORKFLOW_MODE=pruned-data
RESTORE_AUTO_BACKFILL=true
RESTORE_GZIP_TEST=false
METRICS_ENABLED=true
METRICS_PORT=9100
RESTORE_WORKER_METRICS_PORT=59100
